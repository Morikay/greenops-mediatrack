# Verrouille la version minimale de Terraform et les providers utilises.
terraform {
  required_version = ">= 1.5.0"

  # Liste les plugins necessaires au projet et les bornes de versions retenues.
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 6.0"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
    tls = {
      source  = "hashicorp/tls"
      version = "~> 4.0"
    }
    local = {
      source  = "hashicorp/local"
      version = "~> 2.5"
    }
  }
}
